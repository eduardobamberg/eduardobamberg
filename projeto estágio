def fibonacci(n):
    sequence = [0, 1]
    while sequence[-1] < n:
        next_value = sequence[-1] + sequence[-2]
        sequence.append(next_value)
    if n in sequence:
        print(f'O número {n} pertence à sequência de Fibonacci.')
    else:
        print(f'O número {n} não pertence à sequência de Fibonacci.')
    return sequence
